      "parameters": {
        "jsCode": "const items = $input.all();\nconst dailyGoal = 1800;\n\nconst newCalories = $input.last().json.meal_calories || 0;\n\nlet remainingCalories;\n\n// Если найдена только 1 строка ИЛИ вообще ничего не найдено\n// (Значит, эта единственная строка — та, что мы только что добавили)\nif (items.length <= 1) {\n  remainingCalories = dailyGoal - newCalories;\n} else {\n  // Берем предпоследнюю строку (индекс length - 2), \n  // так как последняя (length - 1) — это текущий прием пищи\n  const previousEntry = items[items.length - 2].json;\n  const lastRemaining = Number(previousEntry.remaining_calories) || dailyGoal;\n  remainingCalories = lastRemaining - newCalories;\n}\n\nreturn [{\n  json: {\n    user_id: $input.last().json.user_id ,\n    username: $input.last().json.user_name,\n    items: $input.last().json.meal_items,\n    calories: newCalories,\n    calorie_goal: dailyGoal,\n    remaining_calories: remainingCalories,\n    // Передаем номер текущей строки для обновления\n    row_number: items[items.length - 1].json.row_number \n  }\n}];"
      },
