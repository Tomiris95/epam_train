        "jsCode": "// Берем входящий текст\nlet rawData = $input.first().json.output[0].content[0].text;\n\ntry {\n  // 2. Очищаем от ```json ... ``` и лишних пробелов\n  const cleanJson = rawData\n    .replace(/```json/g, \"\") // Удаляем открывающие кавычки\n    .replace(/```/g, \"\")     // Удаляем закрывающие кавычки\n    .trim();                 // Убираем пробелы в начале и конце\n\n  // 3. Превращаем очищенную строку в настоящий объект (словарь)\n  const parsedData = JSON.parse(cleanJson);\n\n  // 4. Возвращаем результат в n8n\n  return {\n    calories: parsedData.calories,\n    items: parsedData.items,\n    username_id:$('Switch').first().json.message.from.id ,\n    username: $('Switch').first().json.message.from.username,\n    text: \"Photo submission\"\n  };\n} catch (e) {\n  // Если что-то пошло не так, выводим ошибку для отладки\n  return {\n    error: \"Parsing failed\",\n    message: e.message,\n    received_text: rawData\n  };\n}"
